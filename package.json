{
  "name": "buzzy-finance-backend",
  "version": "1.0.0",
  "description": "",
  "main": "app/api/server.ts",
  "scripts": {
    "dev": "pnpm run compose:up && tsx watch --env-file=.env.development app/api/server.ts",
    "build": "tsc",
    "start": "node dist/app/api/server.js",
    "lint": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky",
    "test": "jest",
    "watch": "jest --watch --verbose",
    "compose:up": "docker compose -f ./app/infra/docker/docker-compose.yml up -d",
    "compose:stop": "docker compose -f ./app/infra/docker/docker-compose.yml stop",
    "compose:down": "docker compose -f ./app/infra/docker/docker-compose.yml down",
    "migrate": "node-pg-migrate -j ts",
    "migrate:create": "node-pg-migrate -j ts -m ./app/infra/migrations create",
    "migrate:up": "node-pg-migrate  -j ts -m ./app/infra/migrations --envPath .env.development up",
    "migrate:down": " node-pg-migrate -j ts -m ./app/infra/migrations  --envPath .env.development down",
    "migrate:redo": " node-pg-migrate  -j ts -m ./app/infra/migrations --envPath .env.development redo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustapfp/buzzy-finance-service.git"
  },
  "author": "gustapfp",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gustapfp/buzzy-finance-service/issues"
  },
  "homepage": "https://github.com/gustapfp/buzzy-finance-service#readme",
  "packageManager": "pnpm@10.30.0",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "babel-jest": "^30.4.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "node-pg-migrate": "^8.0.4",
    "prettier": "3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vercel": "^54.4.1"
  }
}
