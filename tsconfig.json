{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "paths": {
      "infra/*": ["./app/infra/*"],
      "api/*": ["./app/api/*"]
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["jest", "node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "dist"]
}
